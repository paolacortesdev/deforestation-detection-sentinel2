from rasterio.windows import Window

window = Window(3000, 3000, 2048, 2048)

B2 = dataset_pos1.read(1, window=window).astype(float) /10000
B3 = dataset_pos1.read(2, window=window).astype(float) /10000
B4 = dataset_pos1.read(3, window=window).astype(float) /10000
B8 = dataset_pos1.read(4, window=window).astype(float) /10000
B11 = dataset_pos1.read(6, window=window).astype(float) /10000
B12 = dataset_pos1.read(7, window=window).astype(float) /10000

NDVI = (B8 - B4) / (B8 + B4 + 1e-10)
NBR  = (B8 - B12) / (B8 + B12 + 1e-10)
NDMI = (B8 - B11) / (B8 + B11 + 1e-10)

stack_pos1 = np.stack([
    B2, B3, B4, B8, B11, B12,
    NDVI, NBR, NDMI
], axis=0)

np.save("stack_pos1.npy", stack_pos1)