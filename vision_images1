import os

os.makedirs("bandas", exist_ok=True)

def guardar_banda(banda, nombre):
    banda = banda.astype(np.float32)
    
    # normalizar entre 0 y 1
    banda_norm = (banda - banda.min()) / (banda.max() - banda.min() + 1e-10)
    
    # reducir tamaño para no romper RAM
    banda_small = banda_norm[::10, ::10]
    
    plt.imsave(f"bandas_pos1/{nombre}.png", banda_small, cmap='gray')

guardar_banda(B2_pos1, "B2_pos1")
guardar_banda(B3_pos1, "B3_pos1")
guardar_banda(B4_pos1, "B4_pos1")
guardar_banda(B8_pos1, "B8_pos1")
guardar_banda(B11_pos1, "B11_pos1")
guardar_banda(B12_pos1, "B12_pos1")

dNDVI1 = ndvi_pre1 - ndvi_pos1

plt.imshow(dNDVI1[::10, ::10], cmap='RdYlGn', vmin=-1, vmax=1)
plt.title("dNDVI (Cambio en vegetación)")
plt.colorbar()
plt.show()

dnbr1 = nbr_pre1 - nbr_pos1

plt.imshow(dnbr1[::10, ::10], cmap='RdBu', vmin=-1, vmax=1)
plt.title("dNBR (Severidad de incendio)")
plt.colorbar()
plt.show()

